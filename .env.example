# Railway Environment Variables
# Copy these to your Railway service settings

# Port (Railway sets this automatically)
PORT=8787

# OpenRouter AI - Get key from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=openrouter/free

# Set to true to skip AI calls and return mock data
AI_MOCK=false

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: restrict CORS to your domain (default: allow all)
# CLIENT_ORIGIN=https://your-app.railway.app
